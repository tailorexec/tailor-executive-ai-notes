# Copie para .env.local e preencha para ativar o backend real (Supabase).
# Se deixar em branco, o app roda em MODO MOCK (localStorage), sem backend.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Configuradas apenas no painel do Supabase (Edge Functions secrets), NUNCA no frontend ---
